# Supabase: Dashboard → Project Settings → API
# Database: Dashboard → Project Settings → Database → Connection string

# --- Supabase (Auth + API) ---

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Postgres (Alembic + backend DB access) ---

# Option A — Direct connection (IPv6 network required):
#   postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres
#
# Option B — Session pooler (IPv4-compatible; use this on most home/office networks):
#   Dashboard → Connect → Method: "Session pooler" → port 5432
#   postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres
#
# Do NOT use the transaction pooler (port 6543) — Alembic migrations require a session connection.
# URL-encode special characters in the password.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres

# --- OpenAI (needed once the LLM / embedding layer is wired up) ---

OPENAI_API_KEY=sk-your-openai-api-key
# Chat model for PydanticAI assistant (default: gpt-4o-mini)
OPENAI_CHAT_MODEL=gpt-4o-mini
# Comma-separated allowlist shown in the UI model picker
OPENAI_CHAT_MODELS=gpt-4.1-nano,gpt-4o-mini,gpt-4.1-mini,gpt-4.1,gpt-4o,o4-mini,o3-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# --- Server ---

# Logging: INFO (default) or DEBUG for retrieval/agent/embed detail in this terminal
LOG_LEVEL=DEBUG
PUBLIC_APP_URL=http://localhost:5173

# Hybrid document compiler for evidence-grounded architect-PM Create PMP (default: true).
# Set false to use the legacy monolithic full-document LLM path for comparison/debugging.
PMP_HYBRID_COMPILER=true

# Comma-separated browser origins allowed to call the API (CORS).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --- SiteWise ingestion / retrieval ---

# Supabase Storage bucket for hosted project file uploads (Dashboard → Storage → New bucket).
# Backend uses the service role key; browsers upload through FastAPI, not directly to Storage.
SUPABASE_STORAGE_BUCKET=project-files

# Defaults to ../data from the backend package. Override on a VPS if the corpus
# is mounted elsewhere.
DATA_DIR=../data
INGEST_EMBEDDING_BATCH_SIZE=64
INGEST_SUPPORTED_EXTENSIONS=.pdf,.docx,.md
RETRIEVAL_SEMANTIC_LIMIT=20
RETRIEVAL_FTS_LIMIT=20
RETRIEVAL_FINAL_LIMIT=10
RETRIEVAL_RRF_K=60
RETRIEVAL_NEIGHBOUR_BEFORE=1
RETRIEVAL_NEIGHBOUR_AFTER=1
ASSISTANT_CONTEXT_PASSAGE_LIMIT=6
ASSISTANT_PASSAGE_CONTENT_CHARS=800
OPENAI_RATE_LIMIT_MAX_RETRIES=5

# --- Polar billing / authorization ---

# Keep false locally unless you want billing gates enforced.
POLAR_ENABLED=false
# Use sandbox for workflow tests. Switch to production when taking real payments.
POLAR_ENVIRONMENT=sandbox
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_STARTER_PRODUCT_ID=
POLAR_PROFESSIONAL_PRODUCT_ID=
POLAR_CHECKOUT_SUCCESS_PATH=/billing?checkout=success
POLAR_CUSTOMER_PORTAL_RETURN_PATH=/billing
