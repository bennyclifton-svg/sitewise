# Backend runtime secrets. Copy to deploy/env/sitewise-api.env outside git.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
SUPABASE_STORAGE_BUCKET=project-files
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_MODELS=gpt-4.1-nano,gpt-4o-mini,gpt-4.1-mini,gpt-4.1,gpt-4o,o4-mini,o3-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

PUBLIC_APP_URL=https://sitewise.au
ALLOWED_ORIGINS=https://sitewise.au
LOG_LEVEL=INFO

# Stripe is the Phase 7+ billing provider. Keep Polar disabled until the
# Phase 8.5 legacy cutover removes it.
BILLING_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_live_or_test_from_stripe
STRIPE_WEBHOOK_SECRET=whsec_from_stripe
STRIPE_PRICE_ID=price_from_stripe
STRIPE_CHECKOUT_SUCCESS_PATH=/billing?checkout=success
STRIPE_PORTAL_RETURN_PATH=/billing

POLAR_ENABLED=false
POLAR_ENVIRONMENT=sandbox
POLAR_ACCESS_TOKEN=polar_oat_or_pat_from_polar
POLAR_WEBHOOK_SECRET=whsec_from_polar
POLAR_STARTER_PRODUCT_ID=starter-product-id
POLAR_PROFESSIONAL_PRODUCT_ID=professional-product-id
POLAR_CHECKOUT_SUCCESS_PATH=/billing?checkout=success
POLAR_CUSTOMER_PORTAL_RETURN_PATH=/billing

AGENT_RUNTIME_ENABLED=true
HERMES_BINARY_PATH=hermes
HERMES_INVOCATION_MODE=chat_stream
HERMES_MODEL_PROVIDER=openai-api
HERMES_MODEL=gpt-5.1
HERMES_MODEL_OPTIONS=openai-codex:gpt-5.5:gpt-5.5 (Codex),openai-api:gpt-5.1:gpt-5.1 (OpenAI API)
AGENT_PLATFORM_API_KEY=sk-platform-key-for-hermes
AGENT_MCP_URL=http://127.0.0.1:8000/mcp
AGENT_WORKSPACE_ROOT=/app/agent-workspaces
AGENT_MAX_CONCURRENT_TURNS=4
AGENT_TURN_TIMEOUT_SECONDS=180
AGENT_TURN_TOKEN_SECRET=replace-with-long-random-secret
AGENT_MONTHLY_TURN_QUOTA=500

TENDER_WORKER_INPROC_ENABLED=false
TENDER_WORKER_POLL_SECONDS=2
TENDER_WORKER_CONCURRENCY=4
TENDER_JOB_MAX_ATTEMPTS=3
TENDER_JOB_BACKOFF_BASE_SECONDS=30
TENDER_JOB_STALE_LOCK_MINUTES=10

DATA_DIR=../data
INGEST_EMBEDDING_BATCH_SIZE=64
INGEST_SUPPORTED_EXTENSIONS=.pdf,.docx,.md
RETRIEVAL_SEMANTIC_LIMIT=20
RETRIEVAL_FTS_LIMIT=20
RETRIEVAL_FINAL_LIMIT=10
RETRIEVAL_RRF_K=60
RETRIEVAL_NEIGHBOUR_BEFORE=1
RETRIEVAL_NEIGHBOUR_AFTER=1
ASSISTANT_CONTEXT_PASSAGE_LIMIT=6
ASSISTANT_PASSAGE_CONTENT_CHARS=800
OPENAI_RATE_LIMIT_MAX_RETRIES=5
